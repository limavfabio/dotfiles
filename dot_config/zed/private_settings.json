{
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "diff_view_style": "unified",
  "edit_predictions": {
    "provider": "zed",
  },
  "context_servers": {
    "tidewave-mcp": {
      "settings": {},

      "enabled": true,
      "url": "http://localhost:3000/tidewave/mcp",
    },
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "project_notifications": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "subagent": true,
          "thinking": true,
          "web_search": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "tidewave-mcp": {
            "tools": {
              "project_eval": false,
              "get_source_location": true,
              "get_models": true,
              "get_logs": true,
              "get_docs": true,
              "execute_sql_query": false,
            },
          },
          "mcp-server-context7": {
            "tools": {
              "resolve-library-id": true,
              "query-docs": true,
            },
          },
        },
      },
    },
    "inline_assistant_model": {
      "provider": "ZAI",
      "model": "GLM-4.7",
    },
    "default_profile": "write",
    "default_model": {
      "provider": "ZAI",
      "model": "GLM-4.7",
    },
    "use_modifier_to_send": false,
    "play_sound_when_agent_done": true,
  },
  "restore_on_startup": "last_session",
  "icon_theme": "Colored Zed Icons Theme Dark",
  "cursor_blink": false,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_weight": 300,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark",
  },
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop", "!solargraph"],
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
  },
  "lsp": {
    "ruby-lsp": {
      "settings": {
        "use_bundler": true,
      },
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false,
        },
      },
    },
    "rubocop": {
      "initialization_options": {
        "safeAutocorrect": false,
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "erb": "html",
          "ruby": "html",
        },
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"],
        },
      },
    },
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore",
          },
        },
      },
    },
  },
  "auto_install_extensions": {
    "html": true,
    "dockerfile": true,
    "docker-compose": true,
    "ruby": true,
    "emmet": true,
    "ruff": true,
    "golangci-lint": true,
    "colored-zed-icons-theme": true,
    "templ": true,
    "mermaid": true,
    "toml": true,
    "git-firefly": true,
    "make": true,
    "rainbow-csv": true,
    "mcp-server-context7": true,
    "sql": true,
  },
}
