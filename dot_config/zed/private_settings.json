{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left"
  },
  "agent_servers": {},
  "diff_view_style": "unified",
  "edit_predictions": {
    "enabled": false
  },
  "context_servers": {},
  "agent": {
    "enabled": false
  },
  "restore_on_startup": "last_session",
  "icon_theme": "Colored Zed Icons Theme Dark",
  "cursor_blink": false,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_weight": 300,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark"
  },
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop", "!solargraph"]
    },
    "HTML+ERB": {
      "language_servers": ["herb", "ruby-lsp"]
    },
    "JS+ERB": {
      "language_servers": ["ruby-lsp"]
    },
    "YAML+ERB": {
      "language_servers": ["ruby-lsp"]
    }
  },
  "lsp": {
    "ruby-lsp": {
      "settings": {
        "use_bundler": true
      },
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false
        }
      }
    },
    "rubocop": {
      "initialization_options": {
        "safeAutocorrect": true
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"]
        }
      }
    }
  },
  "auto_install_extensions": {
    "html": true,
    "dockerfile": true,
    "docker-compose": true,
    "ruby": true,
    "emmet": true,
    "ruff": true,
    "golangci-lint": true,
    "colored-zed-icons-theme": true,
    "templ": true,
    "mermaid": true,
    "toml": true,
    "git-firefly": true,
    "make": true,
    "rainbow-csv": true,
    "sql": true
  }
}
