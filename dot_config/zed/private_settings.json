{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right"
  },
  "agent_servers": {},
  "diff_view_style": "unified",
  "edit_predictions": {
    "provider": "zed"
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": ""
      }
    }
  },
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": true,
        "effort": "xhigh"
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4-mini",
        "enable_thinking": true,
        "effort": "high"
      }
    ],
    "dock": "left",
    "tool_permissions": {
      "default": "allow"
    },
    "profiles": {},
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.4-mini"
    },
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.4"
    },
    "use_modifier_to_send": false,
    "play_sound_when_agent_done": "always"
  },
  "restore_on_startup": "last_session",
  "icon_theme": "Colored Zed Icons Theme Dark",
  "cursor_blink": false,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_weight": 300,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark"
  },
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop", "!solargraph"]
    }
  },
  "lsp": {
    "ruby-lsp": {
      "settings": {
        "use_bundler": true
      },
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false
        }
      }
    },
    "rubocop": {
      "initialization_options": {
        "safeAutocorrect": true
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "erb": "html",
          "ruby": "html"
        },
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"]
        }
      }
    },
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore"
          }
        }
      }
    }
  },
  "auto_install_extensions": {
    "html": true,
    "dockerfile": true,
    "docker-compose": true,
    "ruby": true,
    "emmet": true,
    "ruff": true,
    "golangci-lint": true,
    "colored-zed-icons-theme": true,
    "templ": true,
    "mermaid": true,
    "toml": true,
    "git-firefly": true,
    "make": true,
    "rainbow-csv": true,
    "mcp-server-context7": true,
    "sql": true
  }
}
